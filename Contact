<style>
.container{max-width:800px;margin:auto;padding:40px 40px 100px;}
.page-header{margin-bottom:60px;}
.page-header h1{
font-family:'Cormorant Garamond', serif;
font-size:48px;line-height:1.15;margin-bottom:16px;
}
.page-header p{
font-size:18px;color:#5c524a;line-height:1.7;
}
.contact-body{
background:#fff;border-radius:28px;
padding:60px;
box-shadow:0 15px 40px rgba(0,0,0,0.05);
}
.contact-body h2{
font-family:'Cormorant Garamond', serif;
font-size:28px;margin-bottom:16px;
}
.contact-body p{
font-size:16px;color:#5c524a;
line-height:1.8;margin-bottom:24px;
}
/* EDITAR: reemplaza con tu email real */
.email-card{
background:#F5F1EB;
border-radius:16px;
padding:28px 32px;
margin:32px 0;
display:flex;
align-items:center;
gap:16px;
}
.email-icon{
width:44px;height:44px;border-radius:50%;
background:#C4D0C1;flex-shrink:0;
display:flex;align-items:center;justify-content:center;
}
.email-icon svg{
width:20px;height:20px;
stroke:#2f2a26;fill:none;
stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round;
}
.email-info p{margin:0;font-size:14px;color:#8a8076;margin-bottom:4px;}
/* EDITAR: reemplaza con tu email real */
.email-info a{
font-size:17px;font-weight:600;
color:#2f2a26;text-decoration:none;
transition:opacity .2s;
}
.email-info a:hover{opacity:0.7;}
.topics{
display:grid;grid-template-columns:1fr 1fr;
gap:16px;margin-top:32px;
}
.topic{
background:#F5F1EB;
border-radius:14px;padding:20px;
}
.topic h4{font-size:14px;font-weight:600;margin-bottom:6px;}
.topic p{font-size:13px;color:#6b6158;line-height:1.5;margin:0;}
@media(max-width:900px){
.container{padding:30px 20px 80px;}
.contact-body{padding:32px 24px;}
.page-header h1{font-size:36px;}
.topics{grid-template-columns:1fr;}
.email-card{flex-direction:column;text-align:center;}
}
</style>
</head>
